# ─────────────────────────────────────────────
#  EVM Wallet Bot  — environment configuration
# ─────────────────────────────────────────────

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=walletdb
DB_SSLMODE=disable

# Connection pool configuration
# DB_MAX_CONNS = maximum number of connections in the pool (default: 30)
# DB_MIN_CONNS = minimum number of idle connections (default: 5)
DB_MAX_CONNS=30
DB_MIN_CONNS=5

# Generator tuning
# WORKERS  = number of parallel goroutines generating keys
# BATCH_SIZE = wallets per DB insert transaction (max 1000 recommended)
WORKERS=16
BATCH_SIZE=500

# Log level: info | warn | error
LOG_LEVEL=info

# Optional logging control
# Set to false to disable batch completion logs (reduces I/O overhead for large runs)
ENABLE_LOGGING=true

# Pool monitoring configuration (Optional)
# POOL_MONITOR_INTERVAL = seconds between pool stats logs (0 to disable, default: 30)
# POOL_WARNING_THRESHOLD = warn when pool usage exceeds this ratio (0.0-1.0, default: 0.8)
POOL_MONITOR_INTERVAL=30
POOL_WARNING_THRESHOLD=0.8
